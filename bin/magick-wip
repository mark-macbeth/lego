#!/bin/bash

# Configuration
# 0-100: saturation level (0=grayscale, 100=full color)
saturation=10
# 0.5-2: anti-alias blur amount (higher=smoother)
aa_blur=0.8
# edge detection radius
edge_radius=1
# number of colors for edge detection
edge_colors=2
# background color
background_color='black'
# border color
border_color="red"
# border width
border_width="2x2"

if [[ "$1" == "" ]] ; then
  echo "Create edge-detected border, composite, and desaturate an image"
  echo "usage: magick-wip <input file>"
  echo "output: <dir>/<name>-wip.<ext>"
  echo ""
  echo "Edit the Configuration section at the top of this script to adjust parameters:"
  echo "  - saturation"
  echo "  - aa_blur"
  echo "  - edge_radius"
  echo "  - edge_colors"
  echo "  - background_color"
  echo "  - border_color"
  echo "  - border_width"
  exit 1
fi

input="$1"

# Get directory and filename from input file
input_dir=$(dirname "$input")
input_base=$(basename "$input")
input_name="${input_base%.*}"  # Remove extension
input_ext="${input_base##*.}"  # Get extension

# Create temp files
border_temp=$(mktemp /tmp/magick-wip-border-XXXXXX.${input_ext})
composite_temp=$(mktemp /tmp/magick-wip-composite-XXXXXX.${input_ext})

# Step 1: Create edge-detected border (transparent black background)
magick "$input" -antialias -define filter:blur="$aa_blur" -colors "$edge_colors" -edge "$edge_radius" -transparent "$background_color" "$border_temp"

# Step 2: Composite border on top of original
magick composite "$border_temp" "$input" "$composite_temp"

# Step 3: Desaturate and borderize
output="${input_dir}/${input_name}-wip.${input_ext}"
magick "$composite_temp" -background "$background_color" -alpha remove -modulate 100,"$saturation" -bordercolor "$border_color" -border "$border_width" "$output"

# Clean up temp files
rm -f "$border_temp" "$composite_temp"

echo "Generated: $output"
