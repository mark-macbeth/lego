#!/bin/bash

if [[ "$1" == "" || "$2" == "" ]] ; then
  echo "Reduce saturation and add a red border using ImageMagick"
  echo "usage: magick-desaturate-and-borderize <input file> <saturation 0-100>"
  echo "output: <dir>/<name>-desaturate-borderize-<saturation>.<ext>"
  echo "  saturation: 0 = grayscale, 100 = original colors"
  exit 1
fi

input="$1"
saturation="$2"

# Get directory and filename from input file
input_dir=$(dirname "$input")
input_base=$(basename "$input")
input_name="${input_base%.*}"  # Remove extension
input_ext="${input_base##*.}"  # Get extension

# Construct output filename
output="${input_dir}/${input_name}-desaturate-borderize-${saturation}.${input_ext}"

exec magick convert "$input" -background black -alpha remove -modulate 100,"$saturation" -bordercolor red -border 5x5 "$output"
